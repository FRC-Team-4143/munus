# Slack (create a SEPARATE Slack app from Tempus)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Channel to announce new opportunities in (channel ID like C0ABCDE123; blank = off).
# Invite the bot to this channel first.
SLACK_ANNOUNCE_CHANNEL=

# Admin web UI
ADMIN_PASSWORD=changeme
# Optional limited login that can only create/manage opportunities (blank = disabled)
MANAGER_PASSWORD=changeme_manager
SESSION_SECRET=a-long-random-string

# Database
DATABASE_URL=sqlite+aiosqlite:///./munus.db

# Localisation
TIMEZONE=America/New_York

# Season the required-hours total is counted from (ISO date, blank = count all approved hours)
SEASON_START=

# Public base URL used in Slack messages that link back to the student portal
# Production: https://volunteer.marswars.org
BASE_URL=http://localhost:8001

# Reminders
REMINDER_LEAD_HOURS=24          # DM a signed-up student this many hours before their shift
AUTO_REJECT_DAYS=7              # auto-reject a shift a student never logged, N days after it ends (0 = off)

# Database backups (SQLite only)
BACKUP_DIR=backups              # directory for automatic snapshots
BACKUP_KEEP=14                  # number of snapshots to retain
BACKUP_TIME=23:30               # HH:MM 24h local time for the weekly snapshot
BACKUP_DAY=sun                  # day of week for the weekly backup (mon-sun)
