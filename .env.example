# Slack — in production this is actually the same shared app as Tempus/Legion
# (see README's "Sharing one Slack app" note), but the setup steps are the same either way.
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
# Channel to announce new opportunities in (channel ID like C0ABCDE123; blank = off).
# Invite the bot to this channel first.
SLACK_ANNOUNCE_CHANNEL=

# ── Legion SSO + roster ──────────────────────────────────────────────────────
# Both /admin and the student portal are gated by Legion's shared `mw_sso` cookie —
# /admin needs the `munus-admin` (or `munus-manager`) group, the portal needs any active
# member with role=student. There is no local admin password and no student token: grant
# the first admin `munus-admin` in Legion's /admin/groups. SSO_SECRET must be identical
# to Legion's; add Munus's host to Legion's SSO_ALLOWED_RETURN_HOSTS or the return_to
# redirect back to Munus is rejected.
SSO_SECRET=must-match-legion-sso-secret
SSO_SESSION_TTL=43200
SSO_COOKIE_DOMAIN=

# Legion roster API (read-only source of truth Munus mirrors from) + the one-tap SSO
# challenge endpoint /vhours's dashboard link uses (POST /sso/challenge). Must match
# the value Legion has configured as its MUNUS_API_KEY (Tempus and Munus each have
# their own key on Legion's side — this is Munus's, not shared with Tempus).
LEGION_BASE_URL=https://legion.example.org
LEGION_API_KEY=must-match-legions-munus-api-key

# Database
DATABASE_URL=sqlite+aiosqlite:///./munus.db

# Localisation
TIMEZONE=America/New_York

# Season the required-hours total is counted from (ISO date, blank = count all approved hours)
SEASON_START=

# Public base URL used in Slack messages that link back to the student portal
# Production: https://volunteer.marswars.org
BASE_URL=http://localhost:8001

# Reminders
REMINDER_LEAD_HOURS=24          # DM a signed-up student this many hours before their shift
AUTO_REJECT_DAYS=7              # auto-reject a shift a student never logged, N days after it ends (0 = off)

# Database backups (SQLite only)
BACKUP_DIR=backups              # directory for automatic snapshots
BACKUP_KEEP=14                  # number of snapshots to retain
BACKUP_TIME=23:30               # HH:MM 24h local time for the weekly snapshot
BACKUP_DAY=sun                  # day of week for the weekly backup (mon-sun)

# Master switch for automated Slack messages, reminders, and scheduled jobs
UPDATES_ENABLED=true

# Note: most of the settings above (announce channel, timezone, reminder/auto-reject
# timing, backup schedule, updates toggle) are also editable at runtime from
# Admin -> Settings, which writes changes back to this file. BASE_URL is a
# deploy-time value (the compose sets it in production) and is not UI-editable.
